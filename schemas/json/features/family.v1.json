{
  "manifestVersion": "v1",
  "family": "features",
  "directory": "schemas/json/features",
  "filenamePattern": "<schema-name>.v{major}.schema.json",
  "schemaVersionPolicy": "Additive changes stay within the active major version. Breaking changes require a new major schema filename and explicit consumer rollout.",
  "supportedSchemaVersions": [
    "v1"
  ],
  "purpose": "Derived per-venue and composite state used by visibility, regime gating, and later alert logic.",
  "reservedFields": [
    "schemaVersion",
    "symbol",
    "venue",
    "compositeId",
    "marketType",
    "exchangeTs",
    "recvTs",
    "bucketSource",
    "feedHealthState",
    "replayRef"
  ],
  "plannedSchemas": [
    "venue-bar-30s.v1.schema.json",
    "venue-bar-2m.v1.schema.json",
    "venue-bar-5m.v1.schema.json",
    "composite-market-state.v1.schema.json",
    "feed-health-state.v1.schema.json",
    "market-state-current-symbol.v1.schema.json",
    "market-state-current-global.v1.schema.json",
    "market-state-current-response.v1.schema.json",
    "market-state-recent-context.v1.schema.json",
    "market-state-history-symbol.v1.schema.json",
    "market-state-history-global.v1.schema.json",
    "market-state-audit-provenance.v1.schema.json"
  ]
}
