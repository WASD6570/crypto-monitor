    "timestampStatus",
    "replayRef",
    "sourceRecordId"
  ],
  "plannedSchemas": [
    "replay-seed.v1.schema.json",
    "replay-window.v1.schema.json",
    "replay-request.v1.schema.json",
    "replay-checkpoint.v1.schema.json",
    "replay-audit-record.v1.schema.json",
    "replay-run-manifest.v1.schema.json",
    "replay-compare-summary.v1.schema.json",
    "replay-run-result.v1.schema.json",
    "market-state-audit-lineage.v1.schema.json"
  ]
}
