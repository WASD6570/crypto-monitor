{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/json/replay/replay-run-result.v1.schema.json",
  "title": "Replay Run Result v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "runId",
    "status",
    "inputCounters",
    "startedAt",
    "finishedAt",
    "manifestDigest"
  ],
  "properties": {
    "schemaVersion": {
      "const": "v1"
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["completed", "failed"]
    },
    "failureCategory": {
      "type": "string"
    },
    "inputCounters": {
      "type": "object",
      "required": ["partitions", "events", "duplicates", "lateEvents", "degradedTimestampEvents"],
      "properties": {
        "partitions": {"type": "integer", "minimum": 0},
        "events": {"type": "integer", "minimum": 0},
        "duplicates": {"type": "integer", "minimum": 0},
        "lateEvents": {"type": "integer", "minimum": 0},
        "degradedTimestampEvents": {"type": "integer", "minimum": 0}
      }
    },
    "outputDigest": {
      "type": "string",
      "minLength": 1
    },
    "artifactRefs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "namespace", "digest"],
        "properties": {
          "kind": {"type": "string", "minLength": 1},
          "namespace": {"type": "string", "minLength": 1},
          "digest": {"type": "string", "minLength": 1}
        }
      }
    },
    "comparisonSummaryRef": {
      "type": "object",
      "required": ["kind", "namespace", "digest"],
      "properties": {
        "kind": {"type": "string", "minLength": 1},
        "namespace": {"type": "string", "minLength": 1},
        "digest": {"type": "string", "minLength": 1}
      }
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "finishedAt": {
      "type": "string",
      "format": "date-time"
    },
    "manifestDigest": {
      "type": "string",
      "minLength": 1
    }
  }
}
