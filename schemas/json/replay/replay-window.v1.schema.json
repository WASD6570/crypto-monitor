{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/json/replay/replay-window.v1.schema.json",
  "title": "Replay Window v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "id",
    "symbol",
    "startTs",
    "endTs",
    "fixtureRefs"
  ],
  "properties": {
    "schemaVersion": {
      "const": "v1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "symbol": {
      "type": "string",
      "enum": ["BTC-USD", "ETH-USD"]
    },
    "startTs": {
      "type": "string",
      "format": "date-time"
    },
    "endTs": {
      "type": "string",
      "format": "date-time"
    },
    "fixtureRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
